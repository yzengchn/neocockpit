# LLM提供商配置（用于生成提示词）
# 可选: openai/doubao/dashscope
LLM_PROVIDER=openai

# API Keys（根据使用的提供商配置对应的key）
OPENAI_API_KEY=
DOUBAO_API_KEY=
DASHSCOPE_API_KEY=

# OpenAI LLM 配置（LLM_PROVIDER=openai 时使用）
OPENAI_CHAT_MODEL=gpt-4-turbo-preview
OPENAI_CHAT_BASE_URL=https://api.openai.com/v1

# DashScope LLM 配置（LLM_PROVIDER=dashscope 时使用）
DASHSCOPE_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-turbo

# Doubao LLM 配置（LLM_PROVIDER=doubao 时使用）
DOUBAO_CHAT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_CHAT_MODEL=doubao-pro-32k

# HTTP 重试配置（LLM / 视频适配器）
HTTP_RETRY_ATTEMPTS=3
HTTP_RETRY_BASE_DELAY_SECONDS=2
HTTP_RETRY_MAX_DELAY_SECONDS=30

# 数据库（生产使用 PostgreSQL；表结构由手动 SQL 或迁移脚本维护，业务启动不自动建表/修表）
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/neocockpit
BUSINESS_TIMEZONE=Asia/Shanghai

# 文件存储路径
OUTPUT_DIR=../output

# CORS 允许来源（Cloudflare Pages 通过同域 /api 代理访问时通常不会触发跨域；
# 保留生产域名用于直连 API、调试或管理端跨域访问）
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","https://neocockpit.cn","https://admin.neocockpit.cn"]

# 管理端鉴权配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

LOG_LEVEL=INFO
LOG_DIR=../logs
LOG_RETENTION_DAYS=7

# 用户端 Token 有效期（小时）
# 默认 720 小时 = 30 天；修改后新签发的用户 Token 生效
USER_TOKEN_LIFETIME_HOURS=720

# 打包下载一次性 ticket 有效期（秒）
DOWNLOAD_TICKET_TTL_SECONDS=600
